{
    "name": "@ianlucas/depot-downloader",
    "description": "A DepotDownloader wrapper for TypeScript",
    "license": "MIT",
    "author": "Ian Lucas",
    "homepage": "https://github.com/ianlucas/node-depot-downloader#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ianlucas/node-depot-downloader.git"
    },
    "bugs": {
        "url": "https://github.com/ianlucas/node-depot-downloader/issues"
    },
    "type": "module",
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "sideEffects": false,
    "scripts": {
        "docs": "typedoc --out docs src/index.ts",
        "format": "prettier . --write",
        "postinstall": "node dist/scripts/postinstall.js",
        "prepack": "([ -d dist ] && rm -rf dist); tsc",
        "test": "vitest --run --testTimeout 60000",
        "upgrade": "npx npm-check-updates@latest --target minor -u"
    },
    "devDependencies": {
        "@total-typescript/tsconfig": "^1.0.4",
        "@types/follow-redirects": "^1.14.4",
        "@types/node": "^22.19.17",
        "@types/unzipper": "^0.10.11",
        "prettier": "3.8.2",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    },
    "dependencies": {
        "follow-redirects": "^1.16.0",
        "unzipper": "^0.12.3"
    },
    "engines": {
        "node": ">=20"
    }
}
